#
# NYRO declarative config (DB-less mode)
#
# Plugin enablement is managed in nyro.yaml; only resources are defined here.
# Full scenario docs: docs/zh_CN/examples/
#

version: "1.0"

consumers:
  - name: ai-app
    credentials:
      key-auth:
        key: "sk-xxxxx"

services:
  # ── API Service ──
  - name: httpbin
    url: http://httpbin.org

  # ── AI Service ──
  - name: openai
    provider: openai
    url: https://api.deepseek.com

routes:
  # ── API Route ──
  - name: proxy
    service: httpbin
    paths:
      - /*

  # ── AI Route: OpenAI SDK → OpenAI backend (passthrough) ──
  - name: chat-openai
    service: openai
    paths:
      - /v1/chat/completions
    methods: ["POST"]
    plugins:
      - id: key-auth
      - id: ai-proxy

  # ── AI Route: Anthropic SDK → OpenAI backend (protocol conversion) ──
  - name: chat-anthropic-to-openai
    service: openai
    paths:
      - /v1/messages
    methods: ["POST"]
    plugins:
      - id: key-auth
      - id: ai-proxy

  # ── AI Route: Gemini SDK → OpenAI backend (protocol conversion) ──
  - name: chat-gemini-to-openai
    service: openai
    paths:
      - /v1beta/models/*
    methods: ["POST"]
    plugins:
      - id: key-auth
      - id: ai-proxy
